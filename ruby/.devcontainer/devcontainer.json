{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/refs/heads/main/schemas/devContainer.schema.json",
  "name": "Example devcontainer for ruby",
  "runArgs": [
    "--name",
    "example-devcontainer-for-ruby-${devcontainerId}"
  ],
  "build": {
    "dockerfile": "Dockerfile",
    "cacheFrom": "type=registry,ref=ghcr.io/dhhyi/dcc-devcontainer-ruby-cache"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "[ruby]": {
          "editor.defaultFormatter": "misogi.ruby-rubocop"
        },
        "files.exclude": {
          ".devcontainer": true,
          ".update_devcontainer.sh": true,
          ".vscode": true
        }
      },
      "extensions": [
        "rebornix.Ruby",
        "misogi.ruby-rubocop"
      ]
    }
  },
  "containerEnv": {
    "DCC_SELFTEST": "cnVieSAtZSAncHV0cyAiSGVsbG8gV29ybGQhIic="
  }
}
