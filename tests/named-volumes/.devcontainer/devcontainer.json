{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/refs/heads/main/schemas/devContainer.schema.json",
  "mounts": [
    "type=volume,target=${containerWorkspaceFolder}/node_modules,source=dcc-test-node-modules",
    "type=volume,target=/home/ubuntu/.cache/pnpm,source=dcc-test-pnpm-cache"
  ],
  "postCreateCommand": "sudo mkdir -p node_modules /home/ubuntu/.cache/pnpm && sudo chown -Rf ubuntu node_modules && sudo chown -Rf ubuntu /home/ubuntu",
  "image": "ghcr.io/dhhyi/dcc-devcontainer-javascript-pnpm",
  "customizations": {
    "vscode": {
      "settings": {
        "files.exclude": {
          ".devcontainer": true,
          ".update_devcontainer.sh": true,
          ".vscode": true
        }
      }
    }
  },
  "containerEnv": {
    "DCC_SELFTEST": "bWtkaXIgLXAgJEhPTUUvcHJvamVjdApjZCAkSE9NRS9wcm9qZWN0CmVjaG8gJ3sibmFtZSI6InRlc3QiLCJkZXBlbmRlbmNpZXMiOnsicHJldHRpZXIiOiIqIn19JyA+IHBhY2thZ2UuanNvbgpwbnBtIGluc3RhbGwKLi9ub2RlX21vZHVsZXMvLmJpbi9wcmV0dGllciAtLXZlcnNpb24K"
  }
